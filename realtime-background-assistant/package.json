{
  "name": "@lain14138/realtime-background-assistant",
  "version": "2026.3.13",
  "description": "OpenClaw realtime background assistant plugin",
  "type": "module",
  "files": [
    "README.md",
    "README.zh-CN.md",
    "index.ts",
    "openclaw.plugin.json",
    "openclaw-plugin-sdk.d.ts",
    "src/chat-attachments.ts",
    "src/logger.ts",
    "src/config.ts",
    "src/channel.ts",
    "src/screenshot.ts",
    "src/service.ts"
  ],
  "scripts": {
    "pack:npm": "node ./scripts/package-ops.mjs pack-npm",
    "pack:plugin": "node ./scripts/package-ops.mjs pack-plugin",
    "publish:npm": "node ./scripts/package-ops.mjs publish-npm",
    "publish:openclaw": "node ./scripts/upgrade-via-source.mjs",
    "publish:openclaw:force": "node ./scripts/upgrade-via-source.mjs --force",
    "agent:e2e": "node ./scripts/agent/bootstrap-local-e2e.mjs",
    "test": "vitest run",
    "test:integration": "vitest run src/screenshot.integration.test.ts"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.48"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.24"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "minHostVersion": ">=2026.3.24"
    }
  },
  "devDependencies": {
    "vitest": "^4.1.2"
  }
}
