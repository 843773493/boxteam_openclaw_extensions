{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug OpenClaw with realtime-background-assistant",
      "type": "node",
      "request": "launch",
      "program": "${env:APPDATA}/npm/node_modules/openclaw/openclaw.mjs",
      "cwd": "${workspaceFolder}",
      "args": ["gateway", "--allow-unconfigured", "--verbose"],
      "sourceMaps": true,
      "resolveSourceMapLocations": ["${workspaceFolder}/**", "!**/node_modules/**", "!**/.openclaw-debug/**"],
      "env": {
        "OPENCLAW_CONFIG_PATH": "${workspaceFolder}/.vscode/openclaw.debug.json",
        "OPENCLAW_STATE_DIR": "${workspaceFolder}/.openclaw-debug",
        "OPENCLAW_SKIP_CHANNELS": "1"
      },
      "preLaunchTask": "openclaw:prepare-debug",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "autoAttachChildProcesses": true
    }
  ]
}